# =============================================================================
# Excalidraw – fuente única de variables de entorno
# .env.development y .env.production están vaciados; todo vive aquí.
# Vite hornea (bakes) las vars VITE_APP_* en el bundle estático en BUILD TIME.
# Para Docker: edita este archivo y ejecuta: docker compose up --build
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
# NODE_ENV controla el modo de build de Node (production / development)
NODE_ENV=
# Puerto donde corre el dev server de Vite (no afecta al contenedor nginx)
VITE_APP_PORT=
# Deshabilita Fast Refresh de React en el dev server
FAST_REFRESH=

# ── Backend de almacenamiento de escenas (share links) ────────────────────────
# Servicio público de excalidraw.com para guardar/cargar escenas por URL
VITE_APP_BACKEND_V2_GET_URL=
VITE_APP_BACKEND_V2_POST_URL=

# ── Librería de elementos ─────────────────────────────────────────────────────
# Catálogo público de shapes/stickers de la comunidad
VITE_APP_LIBRARY_URL=
VITE_APP_LIBRARY_BACKEND=

# ── Colaboración en tiempo real (WebSocket) ───────────────────────────────────
# El BROWSER se conecta directamente a esta URL (no el servidor).
# Docker local  → http://localhost:3002  (contenedor excalidraw-room)
# Producción    → URL pública de tu instancia de excalidraw-room
VITE_APP_WS_SERVER_URL=

# ── AI backend ────────────────────────────────────────────────────────────────
# Endpoint del servicio de IA (wire-frames → código, etc.)
VITE_APP_AI_BACKEND=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Usado para: autenticación de usuarios y dashboard de dibujos guardados.
# Credenciales de tu proyecto Supabase (Settings → API)
VITE_APP_SUPABASE_URL=
VITE_APP_SUPABASE_ANON_KEY=

# ── Monitoreo / tracking ──────────────────────────────────────────────────────
# Deshabilitar Sentry en self-hosted (no tienes el DSN de excalidraw.com)
VITE_APP_DISABLE_SENTRY=
# Deshabilitar telemetría de uso
VITE_APP_ENABLE_TRACKING=

# ── PWA (Progressive Web App) ─────────────────────────────────────────────────
# Habilita el service worker e instalación como app
VITE_APP_ENABLE_PWA=

# ── Flags de UI ───────────────────────────────────────────────────────────────
# true → el overlay de stats empieza colapsado
VITE_APP_COLLAPSE_OVERLAY=
# true → desactiva el diálogo "¿seguro que quieres salir?" (solo para dev/debug)
VITE_APP_DISABLE_PREVENT_UNLOAD=
# Deshabilitar ESLint en el servidor de dev (acelera arranque)
VITE_APP_ENABLE_ESLINT=
# Deshabilitar live reload / HMR (útil para depurar Service Workers)
VITE_APP_DEV_DISABLE_LIVE_RELOAD=

# ── Debug ─────────────────────────────────────────────────────────────────────
# Muestra bounding box de contenedores de texto (solo debug visual)
VITE_APP_DEBUG_ENABLE_TEXT_CONTAINER_BOUNDING_BOX=
