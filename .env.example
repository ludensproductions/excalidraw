# =============================================================================
# Excalidraw Docker - Variables de entorno (plantilla)
# =============================================================================
# Copia este archivo a .env, rellena los valores y ejecuta:
#   docker compose up -d --build
#
# Para generar las claves de Supabase:
#   node docker/generate-keys.js
# =============================================================================

# =============================================================================
# DevOps / despliegue
# =============================================================================
# Caddy debe hacer reverse_proxy solamente a estos dos puertos del host.
EXCALIDRAW_PORT=3000
EXCALIDRAW_ROOM_PORT=3002

# URLs externas finales, normalmente servidas por Caddy en subdominios distintos.
EXCALIDRAW_PUBLIC_URL=https://draw.example.com
EXCALIDRAW_ROOM_PUBLIC_URL=https://room.example.com

# Supabase NO se publica al host. Excalidraw lo alcanza via nginx
# usando el nombre interno del contenedor Kong dentro de la red Docker.
# Nota: 5432 es PostgreSQL; la API HTTP de Supabase va por 8000.
SUPABASE_INTERNAL_URL=http://kong:8000
SUPABASE_PUBLIC_URL=https://draw.example.com
API_EXTERNAL_URL=https://draw.example.com
SITE_URL=https://draw.example.com
ADDITIONAL_REDIRECT_URLS=

# Base de datos interna. No se publica al host.
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# =============================================================================
# Excalidraw app (build time)
# =============================================================================
NODE_ENV=production
FAST_REFRESH=false

VITE_APP_WS_SERVER_URL=https://room.example.com
VITE_APP_SUPABASE_URL=/
# Copia ANON_KEY de la salida de generate-keys.js
VITE_APP_SUPABASE_ANON_KEY=

# Backend de escenas
VITE_APP_BACKEND_V2_GET_URL=https://json.excalidraw.com/api/v2/
VITE_APP_BACKEND_V2_POST_URL=https://json.excalidraw.com/api/v2/post/

# Libreria de elementos
VITE_APP_LIBRARY_URL=https://libraries.excalidraw.com
VITE_APP_LIBRARY_BACKEND=https://us-central1-excalidraw-room-persistence.cloudfunctions.net/libraries

# AI
VITE_APP_AI_BACKEND=https://oss-ai.excalidraw.com

# UI / tracking
VITE_APP_DISABLE_SENTRY=true
VITE_APP_ENABLE_TRACKING=false
VITE_APP_ENABLE_PWA=true
VITE_APP_COLLAPSE_OVERLAY=true
VITE_APP_DISABLE_PREVENT_UNLOAD=
VITE_APP_ENABLE_ESLINT=false
VITE_APP_DEV_DISABLE_LIVE_RELOAD=
VITE_APP_DEBUG_ENABLE_TEXT_CONTAINER_BOUNDING_BOX=false
VITE_APP_FIREBASE_CONFIG={}
VITE_APP_GIT_SHA=

# =============================================================================
# Supabase self-hosted - secrets
# =============================================================================
# Ejecuta: node docker/generate-keys.js
# Copia TODA la salida del script en esta seccion.

POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
SECRET_KEY_BASE=
VAULT_ENC_KEY=
PG_META_CRYPTO_KEY=
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

# =============================================================================
# Supabase self-hosted - configuracion interna
# =============================================================================

# Supavisor
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=excalidraw
POOLER_POOL_MODE=transaction
POOLER_DB_POOL_SIZE=5

# Studio
STUDIO_DEFAULT_ORGANIZATION=Excalidraw
STUDIO_DEFAULT_PROJECT=Excalidraw
OPENAI_API_KEY=

# Auth
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=mail
SMTP_PORT=2500
SMTP_USER=admin
SMTP_PASS=admin
SMTP_SENDER_NAME=Excalidraw
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

# Storage
STORAGE_BACKEND=file
GLOBAL_S3_BUCKET=storage
REGION=local
STORAGE_TENANT_ID=stub
FILE_SIZE_LIMIT=52428800
ENABLE_IMAGE_TRANSFORMATION=false

# PostgREST
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# =============================================================================
# Image versions
# =============================================================================
POSTGRES_IMAGE=supabase/postgres:15.8.1.085
SUPAVISOR_IMAGE=supabase/supavisor:2.9.5
GOTRUE_IMAGE=supabase/gotrue:v2.189.0
POSTGREST_IMAGE=postgrest/postgrest:v14.12
STORAGE_IMAGE=supabase/storage-api:v1.60.4
POSTGRES_META_IMAGE=supabase/postgres-meta:v0.96.6
STUDIO_IMAGE=supabase/studio:2026.06.03-sha-0bca601
KONG_IMAGE=kong/kong:3.9.1
MAILPIT_IMAGE=axllent/mailpit:v1.23
EXCALIDRAW_ROOM_IMAGE=excalidraw/excalidraw-room:latest
